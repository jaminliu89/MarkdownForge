{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownForge",
  "version": "1.0.5",
  "identifier": "com.markdownforge.desktop",
  "build": {
    "frontendDist": "./src-frontend",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkdownForge · 抛光机",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "dragDropEnabled": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "MarkdownForge 抛光机 · 25 主题 · 双向编辑 · PDF/长图导出",
    "longDescription": "MarkdownForge 抛光机 · 中文优化排版 · 25 套主题（基础/极简/中国风/平台/高端设计 5 大分组，含 Ant Design、Apple、Notion、Stripe、Vercel、Linear、法律文书等）· 双向编辑同步 · 单页贴合 PDF · 3x 高清长图 · 命令行 md2pdf · 完全离线"
  }
}