{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownForge",
  "version": "2.1.0",
  "identifier": "com.markdownforge.desktop",
  "build": {
    "frontendDist": "./src-frontend",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkdownForge · 抛光机",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "dragDropEnabled": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Markdown 抛光机 · 26 主题 + 舞台动画",
    "longDescription": "MarkdownForge v2.1 · 26 套主题（新增舞台暗色宋体金 · CSS 滚动动画支持 · SVG 舞台卡）+ 单文件离线 + Chrome 扩展 + 桌面应用。零外部依赖，全部资源内嵌。"
  }
}